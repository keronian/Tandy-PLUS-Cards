				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "These small markers show where connectors can \nprotrude through the back plate without hitting the \nedge of the EX/HX case, for each of the 3 hole positions"
		(at 203.276 124.51 90)
		(layer "Cmts.User")
		(uuid "b0949ef1-424b-4e94-be39-2f3de00e3316")
		(effects
