				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Tandy DMA/Memory PCB outline (approx)."
		(at 63.83 139.558 0)
		(layer "Cmts.User")
		(uuid "b652094d-ea83-4d75-94db-034d8ac766e1")
		(effects
