	(gr_text "Maxium recommended length. \nThis will almost reach the ROM \nwhen a SmartWatch is fitted in an HX.\nTall components this far back will hit \nthe top of the case when the board is\nin the top position."
		(at 33.096 89.52 90)
		(layer "Cmts.User")
		(uuid "1deed0e8-89c3-45f6-97cd-cc91b275518a")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Tandy Serial PCB outline (approx)."
		(at 82.118 133.462 0)
		(layer "Cmts.User")
		(uuid "25d8dea5-27d6-4167-bbf4-45fd3d1adcf3")
		(effects
