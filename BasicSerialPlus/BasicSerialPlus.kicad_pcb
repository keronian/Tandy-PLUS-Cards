				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Board may extend 6mm into these voids around the board supports,"
		(at 118.186 31.1 0)
		(layer "Cmts.User")
		(uuid "27b23f10-3bba-45ba-81f0-f2a1a181b585")
		(effects
