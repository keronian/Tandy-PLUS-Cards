	(gr_text "Board may extend 6mm into these voids around the board supports,"
		(at 128.01 45.79 0)
		(layer "Cmts.User")
		(uuid "0cb942a5-dc68-4f6d-b1fc-e0dced50c2d0")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Safe zone for underside components. Taller components,  such as \nDB connectors,  should perhaps not be quite so close to the shield.\nThe HX shield is sheet metal and about 2.3mm away from this line.\nThe EX shield is floppy cardboard with foil then plastic coating. \nIt is about 0mm away from this line and the shielding on the \ncontacting edge may not be perfect."
		(at 195.32 104.21 90)
		(layer "Cmts.User")
		(uuid "18b40766-a94c-4204-8cd2-8cd933e90347")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "The outline is aligned to 0.127mm grid and is sized to fit \nwithin the magic 100mm by 100mm size limit set by \ncertain PCB manufaturers for very inexpensive boards."
		(at 145.923 31.115 0)
		(layer "Cmts.User")
		(uuid "2d8e774b-cd77-4f27-b20c-a970a66e4066")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Maxium recommended length. \nThis will almost reach the ROM \nwhen a SmartWatch is fitted in an HX.\nTall components this far back will hit \nthe top of the case when the board is\nin the top position."
		(at 42.92 104.21 90)
		(layer "Cmts.User")
		(uuid "3b759bd1-5b87-48b3-ae62-1cf4fd90a503")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "When in the bottom board position, there \nis a plastic structure and screw under this \narea. Traces and fill will be fine within the \narea, however, avoid any through hole pads."
		(at 180.08 45.79 0)
		(layer "Cmts.User")
		(uuid "43d35632-4c08-408d-af0f-6ca5d31f81dd")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Rob Krenecki's 3in1 PCB outline (approx)."
		(at 98.038 157.804 0)
		(layer "Cmts.User")
		(uuid "4b9785d6-1702-4c13-a319-787a393be5b5")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "Tandy DMA/Memory PCB outline (approx)."
		(at 73.654 154.248 0)
		(layer "Cmts.User")
		(uuid "633330ef-a644-4a03-bbec-0fcf0d3fc347")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
		)
	)
	(gr_text "On the HX, there is a screw thread poking \nup here. It will not touch the board, however \nit is taller than the insulated metal shield, \nso avoid using any through hole pads here."
		(at 150.87 69.92 0)
		(layer "Cmts.User")
		(uuid "a954c770-6c63-4b79-997e-fff9071dea5b")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify right)
		)
	)
	(gr_text "ISA bus dimensions mostly taken from the \nIBM 5150 Technical Refererence Manual."
		(at 146.558 38.735 0)
		(layer "Cmts.User")
		(uuid "aa64a1e1-54a3-4d7e-895f-d406a7df5c7c")
		(effects
